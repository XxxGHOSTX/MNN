# PostgreSQL Database Configuration
# Required for ThalosBridge middleware and relational buffer
THALOS_DB_DSN=postgresql://username:password@hostname:port/database
# Example: postgresql://thalos:secure_password@localhost:5432/thalos

# Database connection timeout in seconds (optional, default: 10)
THALOS_DB_CONNECT_TIMEOUT=10

# Hardware ID override for encryption (optional)
# If not set, system hardware fingerprint is used automatically
# Set this for consistent encryption across different hosts (e.g., in clusters)
THALOS_HARDWARE_ID=

# MNN API Configuration
# Host to bind the API server (default: 127.0.0.1 for security)
# Use 0.0.0.0 to bind to all interfaces (required for Docker)
MNN_API_HOST=127.0.0.1

# Port for the API server (default: 8000)
MNN_API_PORT=8000

# Deployment environment name (default: production)
# Common values: production, staging, development
ENVIRONMENT=production

# Enable API authentication (default: false for backward compatibility)
# Set to "true" to require authentication on protected endpoints
API_AUTH_ENABLED=false

# Docker Compose Configuration
# These variables are used by docker-compose.yml
POSTGRES_DB=thalos
POSTGRES_USER=thalos
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_PORT=5432
API_PORT=8000

# Security Notes:
# 1. Never commit actual credentials to version control
# 2. Use strong, randomly generated passwords in production
# 3. Enable SSL for database connections in production
# 4. Restrict MNN_API_HOST to 127.0.0.1 unless needed

# ---------------------------------------------------------
# Security & Query Limits
# ---------------------------------------------------------
# Maximum allowed query length (in characters) to protect against
# excessively large or malicious input payloads.
# If unset, a safe default from config.py will be used.
MAX_QUERY_LENGTH=4096

# Enable or disable rate limiting for the API.
# Set to "true" to enable, "false" to disable.
RATE_LIMIT_ENABLED=true

# Maximum number of requests allowed per client within the rate
# limit window defined below.
RATE_LIMIT_REQUESTS=100

# Size of the rate limit window in seconds.
# Example: 60 = 100 requests per minute when combined with
# RATE_LIMIT_REQUESTS=100 above.
RATE_LIMIT_WINDOW=60

# ---------------------------------------------------------
# Logging & Caching
# ---------------------------------------------------------
# Log level for the application.
# Common values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# INFO is recommended for production; DEBUG for local development.
LOG_LEVEL=INFO

# Log format string used by the Python logging module.
# Leave empty to use the default format in config.py.
# Example includes timestamp, level, logger name, and message.
LOG_FORMAT=%(asctime)s - %(levelname)s - %(name)s - %(message)s

# Maximum number of items to keep in the in-memory cache.
# Higher values may improve performance at the cost of memory usage.
# If unset, a default from config.py will be used.
CACHE_SIZE=1024
